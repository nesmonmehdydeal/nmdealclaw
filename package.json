{
  "name": "nmdealclaw",
  "version": "0.1.0",
  "private": true,
  "description": "Task-first AI workspace scaffold with pluggable runtimes and visible multi-agent control",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
